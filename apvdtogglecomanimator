-- Drag
local dragging, dragInput, dragStart, startPos

button.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = button.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

button.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		button.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

local function startCooldown()
	task.delay(PARRY_COOLDOWN, function()
		canParry = true
	end)
end

local function playParryAnimation()
	local char = LocalPlayer.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end
	hum:LoadAnimation(ParryAnimation):Play()
end

local function tryParry(enemyChar, track)
	if not enabled or not canParry then return end

	-- debounce por track
	if track and firedTracks[track] then return end

	local myChar = LocalPlayer.Character
	if not myChar then return end

	local myRoot = myChar:FindFirstChild("HumanoidRootPart")
	local enemyRoot = enemyChar:FindFirstChild("HumanoidRootPart")
	if not myRoot or not enemyRoot then return end

	if (enemyRoot.Position - myRoot.Position).Magnitude > MAX_DISTANCE then return end

	-- marca o track pra não repetir
	if track then
		firedTracks[track] = true
		track.Stopped:Once(function()
			firedTracks[track] = nil
		end)
	end

	canParry = false
	ParryRemote:FireServer()
	playParryAnimation()
	startCooldown()
end

local function resetKiller()
	if killerConnection then killerConnection:Disconnect() end
	killerAnimator = nil
	killerChar = nil
	killerPlayer = nil
	killerConnection = nil
	firedTracks = {}
end

local function getKiller()
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Team == Teams:FindFirstChild("Killer") then
			return p
		end
	end
end

local function hookKiller()
	local killer = getKiller()
	if not killer or killerPlayer == killer then return end

	resetKiller()
	killerPlayer = killer

	if not killer.Character then
		killer.CharacterAdded:Wait()
	end

	killerChar = killer.Character

	local hum = killerChar:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	killerAnimator = hum:FindFirstChildOfClass("Animator")
	if not killerAnimator then return end

	-- AnimationPlayed como backup imediato
	killerConnection = killerAnimator.AnimationPlayed:Connect(function(track)
		if track.Animation and ATTACK_ANIMS[track.Animation.AnimationId] then
			tryParry(killerChar, track)
		end
	end)
end

-- PreSimulation roda ANTES do Heartbeat — detecta mais cedo no frame
RunService.PreSimulation:Connect(function()
	if not enabled or not canParry then return end

	hookKiller()

	if not killerAnimator or not killerChar then return end

	local tracks = killerAnimator:GetPlayingAnimationTracks()
	for i = 1, #tracks do
		local track = tracks[i]
		if track.Animation and ATTACK_ANIMS[track.Animation.AnimationId] then
			-- só parry se a animação ainda está no começo
			if track.TimePosition <= ANIM_DETECT_WINDOW then
				tryParry(killerChar, track)
			end
			break
		end
	end
end)

Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(resetKiller)
	p:GetPropertyChangedSignal("Team"):Connect(resetKiller)
end)

for _, p in pairs(Players:GetPlayers()) do
	p.CharacterAdded:Connect(resetKiller)
	p:GetPropertyChangedSignal("Team"):Connect(resetKiller)
end

local function toggle()
	enabled = not enabled
	if enabled then
		textLabel.Text = "MitHub AutoParry: ON"
		textLabel.TextColor3 = Color3.fromRGB(0,255,0)
	else
		textLabel.Text = "MitHub AutoParry: OFF"
		textLabel.TextColor3 = Color3.fromRGB(255,0,0)
		resetKiller()
	end
end

button.MouseButton1Click:Connect(toggle)

UserInputService.InputBegan:Connect(function(input, gp)
	if not gp and input.KeyCode == Enum.KeyCode.G then
		toggle()
	end
end)
