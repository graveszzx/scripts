local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Teams = game:GetService("Teams")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local ParryRemote = RS.Remotes.Items:FindFirstChild("Parrying Dagger").parry

local MAX_DISTANCE = 14
local PARRY_COOLDOWN = 30
local ANIM_DETECT_WINDOW = 0.15 -- só parry se a animação tiver < 0.15s rodando

local canParry = true
local enabled = false

local killerAnimator
local killerChar
local killerPlayer
local killerConnection

-- debounce por track pra não chamar tryParry várias vezes na mesma animação
local firedTracks = {}

local ParryAnimation = Instance.new("Animation")
ParryAnimation.AnimationId = "rbxassetid://127096285501517"

local ATTACK_ANIMS = {
	["rbxassetid://113255068724446"] = true,
	["rbxassetid://74968262036854"] = true,
	["rbxassetid://110355011987939"] = true,
	["rbxassetid://139369275981139"] = true,
	["rbxassetid://132817836308238"] = true,
	["rbxassetid://129784271201071"] = true,
	["rbxassetid://133963973694098"] = true,
	["rbxassetid://117042998468241"] = true,
	["rbxassetid://105374834496520"] = true,
	["rbxassetid://111920872708571"] = true,
	["rbxassetid://78432063483146"] = true,
	["rbxassetid://118907603246885"] = true
}

